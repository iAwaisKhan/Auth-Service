# ── Application ──────────────────────────────────────────────────────────────
APP_PORT=8080
APP_ENV=development           # development | production
APP_BASE_URL=http://localhost:8080
# Comma-separated allowed origins for CORS. Use "*" in development only.
# In production, set this to your frontend domain(s) so the oauth_state
# cookie can be sent cross-origin (e.g. "https://app.yourorg.com").
CORS_ALLOWED_ORIGINS=*

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=authdb
DB_SSLMODE=disable            # disable | require | verify-full (use verify-full in prod)
DB_TIMEZONE=UTC

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=               # leave empty for no auth (not recommended in prod)
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_generate_with_openssl_rand_base64_64
JWT_ACCESS_EXPIRY=15m         # access token lifetime (15 minutes recommended)
JWT_REFRESH_EXPIRY=168h       # refresh token lifetime (7 days recommended)

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Register app at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/oauth/google/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Register app at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/oauth/github/callback
